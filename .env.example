# ─── LLM Provider ────────────────────────────────────────────────
# Set to "openrouter" (default) or "ollama" (for local LLM)
LLM_PROVIDER=openrouter

# ─── OpenRouter (minimax-m2.5:free) ──────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=minimax/minimax-m2.5:free
# Optional: comma-separated fallback models if OPENROUTER_MODEL is unavailable
OPENROUTER_MODEL_CANDIDATES=minimax/minimax-m2.5:free,openrouter/auto

# ─── Ollama (future local LLM) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Figma ───────────────────────────────────────────────────────
# Personal Access Token from: figma.com → Settings → Personal access tokens
FIGMA_ACCESS_TOKEN=figd_your_token_here
# Retry tuning for transient Figma API failures (429/5xx)
FIGMA_MAX_RETRIES=5
FIGMA_RETRY_BASE_DELAY=1.5
FIGMA_RETRY_MAX_DELAY=20
